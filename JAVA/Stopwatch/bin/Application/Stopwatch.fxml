<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="10" style="-fx-padding:20;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Application.StopwatchController">
    <Label fx:id="timeLabel" style="-fx-font-size:36px; -fx-font-weight:bold;" text="00:00.00" />
    <HBox alignment="CENTER" spacing="10">
        <Button fx:id="startButton" onAction="#onStart" prefWidth="80" text="Start" />
        <Button fx:id="pauseButton" onAction="#onPause" prefWidth="80" text="Pause" />
        <Button fx:id="resetButton" onAction="#onReset" prefWidth="80" text="Reset" />
    </HBox>
</VBox>
